# API base (Express server)
VITE_API_BASE_URL=http://localhost:3001

# SerpAPI (Google Finance) - server
SERPAPI_KEY=your_serpapi_key

# MongoDB - server
MONGODB_URI=your_mongodb_connection_string

# Optional
